{
    "name": "@all-platforms/app",
    "author": "Workleap",
    "version": "0.0.0",
    "description": "Sample application to test all the telemetry platforms integration.",
    "private": true,
    "license": "Apache-2.0",
    "type": "module",
    "scripts": {
        "dev": "rsbuild dev --config rsbuild.dev.ts",
        "build": "pnpm build:rsbuild && pnpm build:copy-public-files",
        "build:rsbuild": "rsbuild build --config rsbuild.build.ts",
        "build:copy-public-files": "copyfiles -u 1 public/favicon.png dist",
        "serve-build": "pnpm http-server dist --ssl --key ../local.workleap.com-key.pem --cert ../local.workleap.com.pem -p 443 -P https://local.workleap.com? -c-1",
        "eslint": "eslint . --max-warnings=0 --cache --cache-location node_modules/.cache/eslint",
        "typecheck": "tsgo"
    },
    "dependencies": {
        "@tanstack/react-query": "5.96.0",
        "@workleap/common-room": "workspace:*",
        "@workleap/logging": "1.3.7",
        "@workleap/telemetry": "workspace:*",
        "logrocket": "12.1.0",
        "react": "19.2.4",
        "react-dom": "19.2.4",
        "react-router-dom": "7.13.2"
    },
    "devDependencies": {
        "@eslint/js": "9.39.2",
        "@rsbuild/core": "1.7.5",
        "@rspack/core": "1.7.11",
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "@typescript-eslint/parser": "8.58.0",
        "@typescript/native-preview": "7.0.0-dev.20260331.1",
        "@workleap/browserslist-config": "2.1.7",
        "@workleap/eslint-configs": "1.1.15",
        "@workleap/rsbuild-configs": "3.2.4",
        "@workleap/typescript-configs": "3.0.7",
        "browserslist": "4.28.2",
        "copyfiles": "2.4.1",
        "eslint": "9.39.2",
        "http-server": "14.1.1",
        "typescript": "6.0.2",
        "typescript-eslint": "8.58.0"
    }
}
